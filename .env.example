# UpLevel Services — Environment Variables
# Copy this file to .env.local and fill in your values

# Vapi AI Phone Agent
NEXT_PUBLIC_VAPI_KEY=          # From vapi.ai → Account → API Keys
NEXT_PUBLIC_VAPI_ASSISTANT_ID= # From vapi.ai → Assistants → copy ID

# Google Analytics
NEXT_PUBLIC_GA_ID=             # From Google Analytics → Measurement ID (G-XXXXXXXXXX)

# Resend (contact form email delivery)
RESEND_API_KEY=                # From resend.com → API Keys

# Notifications
NOTIFICATION_EMAIL=            # Where form submissions get emailed (e.g. hello@uplevelservices.co)

# Make.com webhook (for CRM automation)
MAKE_WEBHOOK_URL=              # From Make.com → Webhooks → copy URL
