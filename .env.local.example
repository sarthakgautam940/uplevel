# ════════════════════════════════════════════════════════════════════
# UpLevel Services — Environment Variable Reference
# ════════════════════════════════════════════════════════════════════
#
# HOW TO USE THIS FILE
# ──────────────────────────────────────────────────────────────────
# 1. Copy this file to `.env.local` (git-ignored — NEVER commit it)
# 2. Fill in real values
# 3. Add the same keys in Vercel Dashboard → Settings → Environment Variables
#    ▸ For server-only keys: set Environment = Production + Preview + Development
#    ▸ For NEXT_PUBLIC_ keys: same — but understand they ARE bundled into the JS
#
# SECURITY RULES — read before touching anything below
# ──────────────────────────────────────────────────────────────────
# ✅  NEXT_PUBLIC_ prefix  → safe to expose — intentionally client-visible
#                            (Vapi public key, Calendly URL, site URL)
# ❌  No NEXT_PUBLIC_ prefix → server-only — NEVER prefix these with NEXT_PUBLIC_
#                              (Resend, Twilio, phone numbers, email addresses)
#
# If you add a new secret and are unsure:
#   → No NEXT_PUBLIC_ prefix. Always. Prove it should be public before adding it.
# ════════════════════════════════════════════════════════════════════


# ── PUBLIC — bundled into the client JS (safe by design) ─────────

# Canonical domain for metadata + sitemap (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://uplevelservicesllc.com

# Calendly scheduling link
NEXT_PUBLIC_BOOK_URL=https://calendly.com/admin-uplevelservicesllc/30min

# Vapi — PUBLIC key only (designed for client exposure, like Stripe publishable key)
# Get from: https://dashboard.vapi.ai → Account → API Keys
NEXT_PUBLIC_VAPI_PUBLIC_KEY=vapi_pub_...

# Vapi assistant ID — safe to expose (no secrets attached)
NEXT_PUBLIC_VAPI_ASSISTANT_ID=...

# Social URLs — public by nature
NEXT_PUBLIC_SOCIAL_X=https://x.com/YOUR_HANDLE
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/YOUR_HANDLE
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@YOUR_HANDLE
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/YOUR_PAGE


# ── SERVER-ONLY — never prefix with NEXT_PUBLIC_ ─────────────────

# Resend — contact form email delivery
# Get from: https://resend.com → API Keys
# ❌ NEVER add NEXT_PUBLIC_ to this key
RESEND_API_KEY=re_...

# Twilio — SMS alert on new contact submission
# Get from: https://console.twilio.com → Account Info
# ❌ NEVER add NEXT_PUBLIC_ to any of these
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM=+1...

# Delivery destinations (your private contact info)
# ❌ NEVER add NEXT_PUBLIC_ to these
CONTACT_TO_EMAIL=admin@uplevelservicesllc.com
CONTACT_TO_PHONE=+1...
